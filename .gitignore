# ---------------------------------------------------------------------------
# Node.js
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/

# Optional npm/yarn/pnpm caches & lock metadata
.npm
.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Environment / secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
config/config.env
config/*.env
src/config/config.env
src/config/*.env
!**/config.env.example
*.pem
*.key

# ---------------------------------------------------------------------------
# Build / coverage / cache output
# ---------------------------------------------------------------------------
build/
dist/
out/
.next/
.nuxt/
.vuepress/dist
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
coverage/
.nyc_output/
*.lcov

# ---------------------------------------------------------------------------
# Client (CRA / Vite) build artefacts when nested
# ---------------------------------------------------------------------------
client/build/
client/dist/
client/node_modules/

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.tgz
.history/
tmp/
temp/